# Server Configuration
PORT=3000
NODE_ENV=development

# Public URL (used for OAuth callbacks and webhook URLs shown in admin)
# Set this to your actual domain in production, e.g. https://metacapi.yourdomain.com
PUBLIC_URL=http://localhost:3000

# Session secret — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=changeme-set-a-long-random-string-here

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Logging
LOG_LEVEL=info

# --- All Facebook and Zoho credentials are configured via the Admin Panel ---
# --- You do NOT need to set them here anymore                             ---
