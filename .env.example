# Facebook / Meta Configuration
FB_PIXEL_ID=your_pixel_id_here
FB_ACCESS_TOKEN=your_long_lived_access_token_here
FB_APP_SECRET=your_facebook_app_secret_here
FB_TEST_EVENT_CODE=TEST12345   # Remove in production

# Zoho CRM Configuration
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_WEBHOOK_SECRET=your_webhook_signing_secret

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info
