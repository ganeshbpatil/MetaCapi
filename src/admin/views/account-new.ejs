<% pageTitle = 'New Account'; %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="mb-4">
      <a href="/admin" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
      </a>
    </div>

    <div class="card">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-1">New Account</h5>
        <p class="text-muted small mb-4">
          Each account represents one client or business with its own Facebook Pixel
          and Zoho CRM connection.
        </p>

        <% if (error) { %>
          <div class="alert alert-danger small"><%= error %></div>
        <% } %>

        <form method="POST" action="/admin/accounts/new">
          <div class="mb-3">
            <label class="form-label fw-semibold">Account Name</label>
            <input type="text" name="name" class="form-control"
              placeholder="e.g. Acme Corp" required autofocus>
            <div class="form-text">A label to identify this client in your dashboard.</div>
          </div>
          <button type="submit" class="btn btn-warning fw-semibold w-100">
            <i class="bi bi-plus-lg me-1"></i>Create Account
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
