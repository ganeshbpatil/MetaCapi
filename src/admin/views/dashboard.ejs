<% pageTitle = 'Dashboard'; %>

<% if (flash) { %>
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle me-1"></i><%= flash %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-0">Accounts</h4>
    <div class="text-muted small"><%= accounts.length %> configured</div>
  </div>
  <a href="/admin/accounts/new" class="btn btn-warning fw-semibold">
    <i class="bi bi-plus-lg me-1"></i>New Account
  </a>
</div>

<% if (accounts.length === 0) { %>
  <div class="card text-center py-5">
    <div class="card-body">
      <i class="bi bi-inbox fs-1 text-muted"></i>
      <h5 class="mt-3">No accounts yet</h5>
      <p class="text-muted">Create your first account to start tracking conversions.</p>
      <a href="/admin/accounts/new" class="btn btn-warning">Create Account</a>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% accounts.forEach(a => { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <h6 class="fw-bold mb-1"><%= a.name %></h6>
          <div class="text-muted small font-monospace mb-3" style="font-size:.72rem"><%= a.id %></div>

          <div class="d-flex gap-4 mb-3">
            <div>
              <div class="section-header">Facebook Pixel</div>
              <span class="status-dot <%= a.fb_status === 'active' ? 'active' : 'none' %>"></span>
              <span class="small"><%= a.pixel_id || 'Not connected' %></span>
            </div>
            <div>
              <div class="section-header">Zoho CRM</div>
              <span class="status-dot <%= a.zoho_status === 'active' ? 'active' : a.zoho_status === 'pending' ? 'pending' : 'none' %>"></span>
              <span class="small"><%= a.zoho_status === 'active' ? 'Connected' : (a.zoho_status || 'Not connected') %></span>
            </div>
          </div>

          <div class="d-flex gap-2">
            <a href="/admin/accounts/<%= a.id %>" class="btn btn-sm btn-outline-dark">
              <i class="bi bi-gear me-1"></i>Configure
            </a>
            <a href="/admin/accounts/<%= a.id %>/logs" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-list-ul me-1"></i>Logs
            </a>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
<% } %>
