<% pageTitle = account.name + ' — Field Mapping'; %>

<div class="mb-4">
  <a href="/admin/accounts/<%= account.id %>" class="text-muted text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i><%= account.name %>
  </a>
</div>

<% if (flash) { %>
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle me-1"></i><%= flash %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (flashError) { %>
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-x-circle me-1"></i><%= flashError %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (!zohoConnected) { %>
  <div class="alert alert-warning mb-3">
    <i class="bi bi-exclamation-triangle me-1"></i>
    Zoho CRM is not connected — dropdowns will not be available.
    <a href="/admin/accounts/<%= account.id %>" class="alert-link">Connect Zoho first</a> to see your actual field names.
  </div>
<% } else if (zohoFields.length === 0) { %>
  <div class="alert alert-warning mb-3">
    <i class="bi bi-exclamation-triangle me-1"></i>
    Could not fetch Zoho fields — check your connection. Using free-text input as fallback.
  </div>
<% } %>

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
  <div>
    <h5 class="fw-bold mb-1"><i class="bi bi-diagram-3 me-2"></i>Field Mapping</h5>
    <div class="text-muted small">
      Map Zoho CRM fields → Facebook CAPI fields for <strong><%= account.name %></strong>
      <% if (zohoFields.length > 0) { %>
        &nbsp;<span class="badge bg-success-subtle text-success border border-success-subtle">
          <i class="bi bi-check-circle me-1"></i><%= zohoFields.length %> Zoho fields loaded
        </span>
      <% } %>
    </div>
  </div>
  <div class="d-flex gap-2">
    <input type="text" id="searchFields" class="form-control form-control-sm" placeholder="Filter rows…" style="width:160px">
    <button class="btn btn-sm btn-outline-secondary" id="fillDefaultsBtn" type="button">
      <i class="bi bi-magic me-1"></i>Fill Defaults
    </button>
  </div>
</div>

<form method="POST" action="/admin/accounts/<%= account.id %>/field-mapping/save">
<div class="row g-4">

  <div class="col-lg-8">

    <%
    const groups = [...new Set(fbFields.map(f => f.group))];
    const groupIcons = {
      'User Identity':       'bi-person-fill text-primary',
      'Facebook Attribution':'bi-meta text-primary',
      'Campaign & Ad':       'bi-megaphone-fill text-warning',
      'Deal / Revenue':      'bi-currency-dollar text-success',
    };
    groups.forEach(group => {
      const fields = fbFields.filter(f => f.group === group);
    %>
    <div class="card mb-3 field-group">
      <div class="card-header py-2 bg-light">
        <span class="fw-semibold small">
          <i class="bi <%= groupIcons[group] || 'bi-circle' %> me-1"></i><%= group %>
        </span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0" style="font-size:.85rem">
          <thead class="table-light">
            <tr>
              <th style="width:220px">Facebook CAPI Field</th>
              <th>Zoho CRM Field</th>
              <th style="width:80px" class="text-center">Hashed</th>
            </tr>
          </thead>
          <tbody>
            <% fields.forEach(field => { %>
            <tr class="mapping-row" data-label="<%= field.label.toLowerCase() %> <%= field.key.toLowerCase() %>">
              <td>
                <div class="fw-semibold"><%= field.label %></div>
                <div class="font-monospace text-muted" style="font-size:.73rem"><%= field.key %></div>
                <% if (field.required) { %>
                  <span class="badge bg-danger-subtle text-danger" style="font-size:.65rem">Required</span>
                <% } %>
              </td>
              <td>
                <% if (zohoFields.length > 0) { %>
                  <select
                    name="mapping[<%= field.key %>]"
                    class="form-select form-select-sm token-field field-mapping-select"
                    data-default="<%= defaultZohoNames[field.key] || '' %>"
                  >
                    <option value="">— not mapped —</option>
                    <% zohoFields.forEach(zf => { %>
                      <option
                        value="<%= zf.api_name %>"
                        <%= (mappings[field.key] === zf.api_name) ? 'selected' : '' %>
                        data-module="<%= zf.module %>"
                      >
                        <%= zf.label %> &nbsp;·&nbsp; <% /* api name shown in option */ %><%= zf.api_name %> (<%= zf.module %>)
                      </option>
                    <% }); %>
                  </select>
                <% } else { %>
                  <input
                    type="text"
                    name="mapping[<%= field.key %>]"
                    class="form-control form-control-sm token-field field-mapping-input"
                    value="<%= mappings[field.key] || '' %>"
                    placeholder="<%= defaultZohoNames[field.key] || 'Zoho API field name' %>"
                    data-default="<%= defaultZohoNames[field.key] || '' %>"
                  >
                <% } %>
              </td>
              <td class="text-center">
                <% if (field.hash) { %>
                  <span class="badge bg-primary-subtle text-primary" title="SHA-256 hashed before sending to Facebook">
                    <i class="bi bi-shield-lock-fill"></i>
                  </span>
                <% } else { %>
                  <span class="text-muted small">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% }); %>

    <div class="d-flex gap-2 mt-1 mb-4">
      <button type="submit" class="btn btn-primary fw-semibold">
        <i class="bi bi-save me-1"></i>Save Mappings
      </button>
      <a href="/admin/accounts/<%= account.id %>" class="btn btn-outline-secondary">Cancel</a>
    </div>

  </div>

  <!-- Right: reference -->
  <div class="col-lg-4">

    <% if (zohoFields.length > 0) { %>
    <div class="card mb-3">
      <div class="card-header py-2 bg-light">
        <span class="fw-semibold small"><i class="bi bi-list-ul me-1"></i>All Zoho Fields (<%= zohoFields.length %>)</span>
      </div>
      <div class="card-body p-0">
        <input type="text" id="zohoFieldSearch" class="form-control form-control-sm border-0 border-bottom rounded-0"
          placeholder="Search fields…" style="border-radius:0!important">
        <div style="max-height:320px;overflow-y:auto">
          <table class="table table-sm table-hover mb-0" style="font-size:.76rem">
            <tbody id="zohoFieldList">
              <% zohoFields.forEach(zf => { %>
              <tr class="zoho-field-row" data-name="<%= zf.api_name.toLowerCase() %> <%= zf.label.toLowerCase() %>">
                <td class="ps-3 text-muted"><%= zf.label %></td>
                <td class="font-monospace pe-2"><%= zf.api_name %></td>
                <td class="pe-2 text-muted" style="font-size:.68rem"><%= zf.module %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="card bg-light border-0 mb-3">
      <div class="card-body">
        <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-1"></i>Common Zoho Field API Names</h6>
        <table class="table table-sm table-borderless mb-0" style="font-size:.78rem">
          <tbody>
            <tr><td class="text-muted">Email</td><td class="font-monospace">Email</td></tr>
            <tr><td class="text-muted">Mobile</td><td class="font-monospace">Mobile</td></tr>
            <tr><td class="text-muted">First Name</td><td class="font-monospace">First_Name</td></tr>
            <tr><td class="text-muted">Last Name</td><td class="font-monospace">Last_Name</td></tr>
            <tr><td class="text-muted">City</td><td class="font-monospace">City</td></tr>
            <tr><td class="text-muted">State</td><td class="font-monospace">State</td></tr>
            <tr><td class="text-muted">Campaign ID</td><td class="font-monospace">Facebook_Campaign_ID</td></tr>
            <tr><td class="text-muted">Ad ID</td><td class="font-monospace">Facebook_Ad_ID</td></tr>
            <tr><td class="text-muted">Deal Amount</td><td class="font-monospace">Amount</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <div class="alert alert-info small mb-0">
      <i class="bi bi-shield-lock-fill me-1"></i>
      <strong>Hashed fields</strong> are SHA-256 hashed before leaving your server — email, phone, name, and location are never sent as plain text.
    </div>

  </div>

</div>
</form>

<script>
// Fill Defaults button
document.getElementById('fillDefaultsBtn').addEventListener('click', () => {
  // selects
  document.querySelectorAll('.field-mapping-select').forEach(sel => {
    if (sel.value === '' && sel.dataset.default) {
      const opt = [...sel.options].find(o => o.value === sel.dataset.default);
      if (opt) sel.value = sel.dataset.default;
    }
  });
  // text inputs (fallback)
  document.querySelectorAll('.field-mapping-input').forEach(inp => {
    if (!inp.value && inp.dataset.default) inp.value = inp.dataset.default;
  });
});

// Filter mapping rows
document.getElementById('searchFields').addEventListener('input', function () {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.mapping-row').forEach(row => {
    row.style.display = !q || row.dataset.label.includes(q) ? '' : 'none';
  });
});

// Search inside Zoho field list panel
const zohoSearch = document.getElementById('zohoFieldSearch');
if (zohoSearch) {
  zohoSearch.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.zoho-field-row').forEach(row => {
      row.style.display = !q || row.dataset.name.includes(q) ? '' : 'none';
    });
  });
}
</script>
